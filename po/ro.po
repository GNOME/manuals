#: data/app.devsuite.Manuals.desktop.in.in:2
#: data/app.devsuite.Manuals.metainfo.xml.in.in:6 src/manuals-window.c:605
msgid "Manuals"
msgstr "Manuale"

#: data/app.devsuite.Manuals.desktop.in.in:3
msgid "Install, Browse, and Search Documentation"
msgstr "Instalează, răsfoiește și caută documentația"

#. Translators: Search terms to find this application. Do NOT translate or localize the semicolons! The list MUST also end with a semicolon!
#: data/app.devsuite.Manuals.desktop.in.in:13
msgid "documentation;manuals;api;reference;docs;developer;"
msgstr "documentation;manuals;api;reference;docs;developer;documentație;manuale;instrucțiuni;trimitere;programator;"

#: data/app.devsuite.Manuals.metainfo.xml.in.in:7
msgid "Read developer documentation"
msgstr "Citește documentația programatorului"

#: data/app.devsuite.Manuals.metainfo.xml.in.in:9
msgid ""
"Manuals indexes your developer manuals and provides robust browsing and "
"searching capabilities."
msgstr ""
"Aplicația „Manuale” indexează manualele programatorilor și oferă capacități "
"robuste de răsfoire și căutare."

#: data/app.devsuite.Manuals.metainfo.xml.in.in:13
msgid ""
"It supports the devhelp documentation format used by many libraries "
"integrating with the GTK platform."
msgstr ""
"Acceptă formatul de documentație devhelp utilizat de multe biblioteci care "
"se integrează cu platforma GTK."

#: data/app.devsuite.Manuals.metainfo.xml.in.in:31
msgid "Browse Documentation by SDK"
msgstr "Răsfoiește documentația SDK"

#: data/app.devsuite.Manuals.metainfo.xml.in.in:35
msgid "Free Form Search"
msgstr "Căutare liberă"

#: data/app.devsuite.Manuals.metainfo.xml.in.in:39
msgid "Install SDK Documentation"
msgstr "Instalează documentația SDK"

#: data/app.devsuite.Manuals.metainfo.xml.in.in:43
