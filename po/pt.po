msgid "Main Menu"
msgstr "Menu principal"

#: src/manuals-window.ui:122
msgid "Search"
msgstr "Pesquisar"

#: src/manuals-window.ui:168
msgid "Loading…"
msgstr "A carregar…"

#: src/manuals-window.ui:169
msgid "One moment please while we locate your documentation"
msgstr "Aguarde um momento enquanto localizamos a sua documentação"

#: src/manuals-window.ui:187
msgid "Browse Documentation"
msgstr "Procurar documentação"

#: src/manuals-window.ui:194
msgid ""
"• Press Ctrl+K to search for classes and more\n"
"• Press Ctrl+T to open a new tab\n"
"\n"
"Or, press Ctrl+W to close the window"
msgstr ""
"• Pressione Ctrl+K para procurar aulas e mais\n"
"• Pressione Ctrl+T para abrir um novo separador\n"
"\n"
"Ou pressione Ctrl+W para fechar a janela"

